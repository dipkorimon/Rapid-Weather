<!DOCTYPE html>
<html lang="en">
<head>
    {{>header_links}}
</head>
<body>
    <!-- navbar -->
    {{>navbar}}

    <!-- Main header -->
    <div class="container mt-3 mb-3 text-center" style="font-size: 30px;">
        Search with your city name and get <strong class="text-danger">Current Weather Data</strong> of your city. 
    </div>
    <div class="container main_header">
        <div class="main_content d-flex align-items-center justify-content-center mb-3">
            <form class="temp_form d-flex">
                <input class="form-control" type="text" id="cityName" placeholder="Enter your city name" style="width: 100%; max-width: 300px; margin-right: 10px;">
                <input class="btn btn-warning" type="submit" value="Search" id="submitBtn">
            </form>
        </div>
        <div class="tempInformation">
            <p id="city_name" class="text-center text-danger">City Name Here</p>
            <div class="middle_layer data_hide text-center">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered">
                    <thead class="table-secondary">
                        <tr>
                            <th>Temperature</th>
                            <th>Feels Like</th>
                            <th>Minimum Temperature</th>
                            <th>Maximum Temperature</th>
                            <th>Pressure</th>
                            <th>Humidity</th>
                            <th>Weather Mood</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><p id="temp"><strong id="temp_real_val" class="text-danger">0</strong><sup>o</sup> C</p></td>
                            <td><p id="temp"><strong id="temp_feels_like" class="text-danger">0</strong><sup>o</sup> C</p></td>
                            <td><p id="temp"><strong id="temp_temp_min" class="text-danger">0</strong><sup>o</sup> C</p></td>
                            <td><p id="temp"><strong id="temp_temp_max" class="text-danger">0</strong><sup>o</sup> C</p></td>
                            <td><p id="temp"><strong id="pressure" class="text-danger">0</strong> Pa</p></td>
                            <td><p id="temp"><strong id="humidity" class="text-danger">0</strong> gm<sup>3</sup></p></td>
                            <td><p id="temp"><strong id="temp_mood" class="text-danger">Null</strong></p></td>
                        </tr>
                    </tbody>
                </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    {{>footer}}
    
    <script src="js/main.js"></script>

</body>
</html>
